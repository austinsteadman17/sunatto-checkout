# Copy this file to .env for local development (never commit the real .env).
# In Netlify, set these same variables under Site settings > Environment variables instead.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
PORT=3000

# Enables the Monday.com sync (marks the board item "Paid" and notifies
# Nicole when a payment succeeds) AND the /hub.html payment-links page
# (which reads the Sales Rep / Office / Manager columns on the "Sunatto
# Pipeline 2026" board to decide which jobs/links each logged-in person
# can see). Without this, payments still work fine — the Monday sync is
# just skipped and logged, and the hub will show no jobs for anyone. See
# README.md.
MONDAY_API_TOKEN=

# Optional — enables the "Send to Homeowner" email button on intake.html.
# This is a Postmark Server API token (Servers > [your server] > API Tokens).
# Without this, payments/links still work fine; office staff just can't
# auto-email the link and would need to copy/paste it instead. See README.md.
POSTMARK_SERVER_TOKEN=

# Optional — enables address autocomplete on intake.html's Address field.
# This is a Mapbox public access token (starts with pk.) — safe to expose
# to the browser, same trust model as STRIPE_PUBLISHABLE_KEY above.
# Without it, the Address field is just a plain text field. See README.md.
MAPBOX_ACCESS_TOKEN=

# Required for /hub.html (the Payment Links Hub) to actually read/write its
# data. Netlify Blobs is *supposed* to auto-configure with zero setup
# inside any Netlify Function, but that auto-detection doesn't reach
# through this project's serverless-http wrapper, so it needs to be
# configured manually via this token instead. Create a Personal access
# token in Netlify (User settings > Applications > Personal access tokens
# > New access token) and paste it here. See README.md.
NETLIFY_BLOBS_TOKEN=
