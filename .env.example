# Copy this file to .env for local development (never commit the real .env).
# In Netlify, set these same variables under Site settings > Environment variables instead.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
PORT=3000

# Optional — enables the Monday.com sync (marks the board item "Paid" and
# notifies Nicole when a payment succeeds). Without this, payments still
# work fine; the sync is just skipped and logged. See README.md.
MONDAY_API_TOKEN=

# Optional — enables the "Send to Homeowner" email button on intake.html.
# This is a Postmark Server API token (Servers > [your server] > API Tokens).
# Without this, payments/links still work fine; office staff just can't
# auto-email the link and would need to copy/paste it instead. See README.md.
POSTMARK_SERVER_TOKEN=
